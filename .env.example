# ── Server (server/.env) ────────────────────────────────────────────────────
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# OpenAI — required for AI explanation and chat features
OPENAI_API_KEY=sk-...your-key-here...

# ── Client (client/.env) ────────────────────────────────────────────────────
# Leave empty for local dev (Vite proxy handles /api → localhost:3001).
# In production set to your deployed backend URL including /api:
#   e.g. VITE_API_URL=https://your-backend.railway.app/api
VITE_API_URL=
