# ── Server (server/.env) ────────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173

# OpenAI — required for AI explanation and chat features
OPENAI_API_KEY=sk-...your-key-here...

# ── Client (client/.env.local) ───────────────────────────────────────────────
# Leave empty for local dev (falls back to http://localhost:3001/api).
# In production set to your deployed backend URL including /api:
#   e.g. VITE_API_URL=https://your-backend.railway.app/api
VITE_API_URL=
